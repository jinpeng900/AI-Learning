   "source": [
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "\n",
    "\n",
    "x_points = np.arange(0 , 10 , 0.1)\n",
    "y_points = np.sin(x_points)\n",
    "\n",
    "plt.title(\"Sin Wave\")\n",
    "plt.plot(x_points , y_points)\n",
    "plt.xlabel(\"X\" , loc = 'left')\n",
    "plt.ylabel(\"Y\" , loc = 'top')\n",
    "plt.legend([\"Sin Wave\"])\n",
    "plt.grid()\n",
    "plt.show()\n"
   ]
  }
